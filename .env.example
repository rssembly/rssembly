# DATABASE_URL
# Required. PostgreSQL connection string.
DATABASE_URL=postgres://rssembly:rssembly@localhost:5432/rssembly?sslmode=disable

# SERVER_HOST / SERVER_PORT
# Address to listen on. Default: :8080
SERVER_HOST=
SERVER_PORT=8080

# JWT_PRIVATE_KEY / JWT_PUBLIC_KEY
# Optional. Inline PEM-encoded Ed25519 keys. If set, these take priority over
# file-based keys. Perfect for Docker/Kubernetes secrets mounted as env vars.
# Note: PEM lines with \n are valid — set in Docker as:
#   JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMxxx...\n-----END PRIVATE KEY-----
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

# JWT_PRIVATE_KEY_PATH / JWT_PUBLIC_KEY_PATH
# Optional. Paths to PEM files on disk. If neither these files nor the inline
# PEM env vars exist, a new key pair is auto-generated on first startup and
# written to these paths. Default: ./data/jwt_ed25519.pem / .pub
JWT_PRIVATE_KEY_PATH=./data/jwt_ed25519.pem
JWT_PUBLIC_KEY_PATH=./data/jwt_ed25519.pub

# CORS_ALLOWED_ORIGINS
# Comma-separated list of allowed origins. Default: allow all (self-hosted default)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# RATE_LIMIT_REQUESTS / RATE_LIMIT_WINDOW
# Per-IP rate limiting. Default: 100 requests per 1m
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# DEFAULT_POLL_INTERVAL
# Default interval for feed polling. Default: 15m
DEFAULT_POLL_INTERVAL=15m

# LOG_LEVEL
# One of: debug, info, warn, error. Default: info
LOG_LEVEL=debug

# ENCRYPTION_KEY
# Required for feed password encryption. 64-character hex string (32 bytes).
# Generate one with: openssl rand -hex 32
# ENCRYPTION_KEY=