#!/bin/sh
# Pre-commit hook: run golangci-lint fmt on staged Go files.
# Requires golangci-lint v2 to be installed in GOPATH.

STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$')

if [ -z "$STAGED_GO_FILES" ]; then
    exit 0
fi

GOLANGCI_LINT=$(go env GOPATH)/bin/golangci-lint
if [ ! -x "$GOLANGCI_LINT" ]; then
    echo "⚠️  golangci-lint not found at $GOLANGCI_LINT"
    echo "   Install with: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest"
    exit 1
fi

echo "→ Running golangci-lint fmt on staged Go files..."
for file in $STAGED_GO_FILES; do
    if [ -f "$file" ]; then
        # Format in-place using configured formatters (gofmt -s)
        "$GOLANGCI_LINT" fmt "$file" 2>/dev/null
        # Stage any formatting changes
        git add "$file"
    fi
done

echo "✓ golangci-lint fmt complete"
